<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Inmobiliaria" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/azul_sofisticado</item>
        <item name="colorPrimaryVariant">#0D1B2A</item>
        <item name="colorOnPrimary">@color/white</item>


        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="drawerArrowStyle">@style/CustomDrawerArrowStyle</item>
        <item name="android:statusBarColor">@color/azul_sofisticado</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="editTextStyle">@style/AppEditText</item>
        <item name="buttonStyle">@style/AppButton</item>
        <item name="materialButtonStyle">@style/AppButton</item>
    </style>


    <style name="AppEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/input_background_dark</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
    </style>

    <style name="LoginEditText" parent="AppEditText">
        <item name="android:background">@drawable/input_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">#CCFFFFFF</item>
    </style>

    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="Theme.Inmobiliaria.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Inmobiliaria.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Inmobiliaria.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <style name="CustomDrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">@color/white</item>
    </style>
</resources>